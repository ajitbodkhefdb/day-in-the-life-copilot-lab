@model StudentIndexViewModel

@{
    ViewBag.Title = "Students";
}

<h2>Students</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<form asp-action="Index" method="get">
    <div class="form-actions no-color">
        <p>
            Find by name: <input type="text" name="SearchString" value="@Model.CurrentFilter" />
            <input type="submit" value="Search" class="btn btn-default" /> |
            <a asp-action="Index" class="btn btn-secondary btn-sm">Clear Search</a>
        </p>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.CurrentFilter))
{
    <p class="text-muted">
        Found <strong>@Model.Students.TotalCount</strong> student(s) matching &ldquo;@Model.CurrentFilter&rdquo;
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@Model.NameSortParm" asp-route-currentFilter="@Model.CurrentFilter">Full Name</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@Model.DateSortParm" asp-route-currentFilter="@Model.CurrentFilter">Enrollment Date</a>
            </th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Students.Any())
        {
            <tr>
                <td colspan="3" class="text-center">
                    No students found matching &ldquo;@Model.CurrentFilter&rdquo;.
                    <a asp-action="Index">Clear search</a>
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Students)
            {
                <tr>
                    <td>
                        @item.FullName
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.EnrollmentDate)
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-info btn-sm">Details</a> |
                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-warning btn-sm">Edit</a> |
                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<a asp-action="Index"
   asp-route-sortOrder="@Model.CurrentSort"
   asp-route-page="@(Model.Students.PageIndex - 1)"
   asp-route-currentFilter="@Model.CurrentFilter"
   class="btn btn-default @(Model.Students.HasPreviousPage ? "" : "disabled")">
   Previous
</a>

<a asp-action="Index"
   asp-route-sortOrder="@Model.CurrentSort"
   asp-route-page="@(Model.Students.PageIndex + 1)"
   asp-route-currentFilter="@Model.CurrentFilter"
   class="btn btn-default @(Model.Students.HasNextPage ? "" : "disabled")">
   Next
</a>

